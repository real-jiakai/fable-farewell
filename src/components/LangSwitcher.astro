---
import { ui } from '../i18n/ui.js';
import { LOCALES, LOCALE_PATHS } from '../i18n/config.js';

interface Props {
  locale: keyof typeof ui;
}

const { locale } = Astro.props;
const t = ui[locale];
---

<div class="fixed right-[max(0.75rem,env(safe-area-inset-right))] top-[max(0.75rem,env(safe-area-inset-top))] z-20 sm:right-[max(1.25rem,env(safe-area-inset-right))] sm:top-[max(1.25rem,env(safe-area-inset-top))]">
  <div class="lang-select relative flex h-11 items-center">
    <svg
      aria-hidden="true"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      class="pointer-events-none absolute left-2.5 h-4 w-4 text-[#cfc7b4]/70"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802"
      />
    </svg>

    <select
      id="lang-select"
      aria-label={t.switcherLabel}
      aria-describedby="lang-select-hint"
      class="lang-select__control h-11 w-full appearance-none rounded-lg border border-[#e8b45a]/20 bg-[#12151f]/90 py-1 pl-8 pr-8 font-numeric text-base uppercase tracking-wide text-[#f2ecdf] backdrop-blur transition-colors hover:border-[#e8b45a]/45 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#e8b45a] focus-visible:ring-offset-2 focus-visible:ring-offset-[#0b0d14]"
      onchange="try{localStorage.setItem('fable-lang',this.value)}catch(e){};location.href=this.options[this.selectedIndex].dataset.href"
    >
      {
        LOCALES.map((loc) => (
          <option value={loc} data-href={LOCALE_PATHS[loc]} selected={loc === locale}>
            {ui[loc].langName}
          </option>
        ))
      }
    </select>

    <svg
      aria-hidden="true"
      viewBox="0 0 20 20"
      fill="currentColor"
      class="pointer-events-none absolute right-2.5 h-3.5 w-3.5 text-[#cfc7b4]/70"
    >
      <path
        fill-rule="evenodd"
        d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z"
        clip-rule="evenodd"
      />
    </svg>
  </div>

  <span id="lang-select-hint" class="sr-only">{t.switcherHint}</span>

  <noscript>
    <nav
      aria-label="Language"
      class="mt-1 flex justify-end gap-2 rounded-lg border border-[#e8b45a]/20 bg-[#12151f]/90 px-2 py-1 font-numeric text-[0.68rem] uppercase tracking-wide"
    >
      {
        LOCALES.map((loc) => (
          <a
            href={LOCALE_PATHS[loc]}
            aria-current={loc === locale ? 'page' : undefined}
            class={loc === locale ? 'text-[#f7f1e3]' : 'text-[#cfc7b4]/70 hover:text-[#f2ecdf]'}
          >
            {ui[loc].langName}
          </a>
        ))
      }
    </nav>
  </noscript>
</div>

<style>
  .lang-select__control {
    -webkit-appearance: none;
    -moz-appearance: none;
  }

  .lang-select__control::-ms-expand {
    display: none;
  }

  .lang-select__control option {
    background-color: #12151f;
    color: #f2ecdf;
  }
</style>
